# Clone a CK repo. Defaults to the sesh .bare worktree layout:
#   ~/dev/<repo>/{.bare, <default-branch>/}
# Use --flat / -f for a plain single-dir clone (old behavior).
# Usage:
#   clone <repo>            # bare layout
#   clone --flat <repo>     # plain git clone into ~/dev/<repo>
function clone() {
  local flat=0
  if [[ "$1" == "--flat" || "$1" == "-f" ]]; then
    flat=1; shift
  fi

  local repo="$1"
  if [[ -z "$repo" ]]; then
    echo "Usage: clone [--flat|-f] <repo>"
    return 1
  fi

  local url="{{ .gitCloneBase }}/$repo"
  local name="${repo%.git}"; name="${name##*/}"
  local dest="$HOME/dev/$name"

  if (( flat )); then
    git clone "$url" "$dest"
    return $?
  fi

  if [[ -e "$dest" ]]; then
    echo "Error: $dest already exists"
    return 1
  fi

  echo "Cloning '$repo' into .bare layout at $dest"
  mkdir -p "$dest" || return 1
  if ! git clone --bare "$url" "$dest/.bare"; then
    echo "Error: bare clone failed"
    rmdir "$dest" 2>/dev/null
    return 1
  fi

  # Make the bare repo fetch like a normal clone, then point worktrees at it.
  git --git-dir="$dest/.bare" config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'
  git --git-dir="$dest/.bare" fetch origin
  echo "gitdir: ./.bare" > "$dest/.git"

  # Check out the default branch as the first worktree.
  local def
  def=$(git --git-dir="$dest/.bare" symbolic-ref --short HEAD 2>/dev/null)
  def="${def:-master}"
  git -C "$dest" worktree add "$def" "$def"
  echo "Done: $dest/$def"
}

# Convert a normal flat clone into the sesh .bare worktree layout, in place.
#   ~/dev/<repo> (flat)  ->  ~/dev/<repo>/{.bare, .git, <branch>/}
# Run per-repo over time; idempotent (skips already-converted repos).
# Requires a clean working tree; keeps a *.flat-backup.* copy until you delete it.
convert-to-bare() {
  local repo_dir="${1:-$PWD}"
  repo_dir="${repo_dir%/}"

  if ! git -C "$repo_dir" rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    echo "Error: Not a git repository: $repo_dir"
    return 1
  fi
  if [[ -d "$repo_dir/.bare" ]]; then
    echo "Already .bare layout: $repo_dir"
    return 0
  fi
  if [[ -n "$(git -C "$repo_dir" status --porcelain)" ]]; then
    echo "Error: uncommitted changes in $repo_dir — commit or stash first"
    return 1
  fi

  local branch
  branch=$(git -C "$repo_dir" branch --show-current)
  [[ -z "$branch" ]] && branch=$(git -C "$repo_dir" rev-parse --abbrev-ref HEAD)

  echo "Converting '$repo_dir' to .bare layout (current branch: $branch)"

  local tmp="${repo_dir}.bare-convert.$$"
  mkdir -p "$tmp" || return 1

  if ! git clone --bare "$repo_dir/.git" "$tmp/.bare"; then
    echo "Error: failed to create bare clone"
    rm -rf "$tmp"
    return 1
  fi

  git --git-dir="$tmp/.bare" config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'
  local origin
  origin=$(git -C "$repo_dir" remote get-url origin 2>/dev/null)
  [[ -n "$origin" ]] && git --git-dir="$tmp/.bare" remote set-url origin "$origin"
  git --git-dir="$tmp/.bare" fetch origin

  echo "gitdir: ./.bare" > "$tmp/.git"

  # Swap into the final location BEFORE adding the worktree: `git worktree add`
  # records absolute paths, so adding it in $tmp then mv'ing would leave the
  # worktree pointing at the (deleted) temp dir.
  local backup="${repo_dir}.flat-backup.$$"
  mv "$repo_dir" "$backup" && mv "$tmp" "$repo_dir"

  if ! git -C "$repo_dir" worktree add "$branch" "$branch"; then
    echo "Error: failed to add worktree for $branch (data safe in $backup)"
    return 1
  fi

  echo "Done. Old clone backed up at $backup"
  echo "Verify, then: rm -rf '$backup'"
  echo "Note: git stashes do NOT transfer to the bare clone — apply any stashed"
  echo "      work from the backup before deleting it."
}

# Show the top 20 directories ≥ 1G under the given path (default ~/dev), sorted largest first.
# Usage: bigdirs            # scans ~/dev
#        bigdirs ~/code     # scans a different root
function bigdirs() {
   local root="${1:-$HOME/dev}"
   du -h "$root" 2>/dev/null | awk '$1 ~ /[0-9]+G/' | sort -hr | head -20
}

