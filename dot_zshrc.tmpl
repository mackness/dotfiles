# Helpful functions
unalias g 2>/dev/null
g() {
  local dir
  dir=$(find ~/dev -mindepth 1 -maxdepth 1 -type d | fzf --height=40% --reverse --prompt="~/dev: ")
  if [[ -n "$dir" ]]; then
    cd "$dir" || echo "Failed to cd into $dir"
  fi
}

# Create a git worktree with a new branch and open it via sesh.
# Assumes the .bare worktree layout (see `clone` / `convert-to-bare`):
#   ~/dev/<repo>/{.bare, <branch>/}  — worktrees are top-level dirs beside .bare.
workspace() {
  if [[ $# -lt 3 ]]; then
    echo "Usage: workspace <repo> <worktree-name> <branch-name>"
    return 1
  fi

  local repo="$1"
  local wt_name="$2"
  local branch="$3"
  local repo_dir="$HOME/dev/$repo"
  local worktree_dir="$repo_dir/$wt_name"

  if [[ ! -d "$repo_dir" ]]; then
    echo "Error: Repository not found: $repo_dir"
    return 1
  fi

  if [[ ! -d "$repo_dir/.bare" ]]; then
    echo "Error: $repo_dir is not a .bare-layout repo."
    echo "       Convert it first with: convert-to-bare $repo_dir"
    return 1
  fi

  # If worktree already exists, just open it
  if [[ -d "$worktree_dir" ]]; then
    echo "Worktree already exists, connecting..."
    zoxide add "$worktree_dir"   # register so it shows in the sesh/zoxide picker
    sesh connect "$worktree_dir"
    return 0
  fi

  echo "Creating worktree '$wt_name' (branch: $branch) in $repo_dir"
  if ! git -C "$repo_dir" worktree add "$worktree_dir" -b "$branch"; then
    echo "Error: Failed to create worktree"
    return 1
  fi

  zoxide add "$worktree_dir"   # register so it shows in the sesh/zoxide picker
  sesh connect "$worktree_dir"
}

# List all worktrees across .bare-layout repos in an fzf picker and connect via sesh.
# Scans ~/dev/<repo>/ dirs that contain a .bare folder; lists their worktree subdirs.
workspaces() {
  local selected
  selected=$(
    for repo_dir in ~/dev/*; do
      [[ -d "$repo_dir/.bare" ]] || continue
      local repo_name="${repo_dir##*/}"
      for wt in "$repo_dir"/*/; do
        wt="${wt%/}"
        local wt_name="${wt##*/}"
        # skip the bare dir itself
        [[ "$wt_name" == ".bare" ]] && continue
        echo "$repo_name/$wt_name"
      done
    done | fzf --height=40% --reverse --prompt="Workspace: "
  )

  if [[ -n "$selected" ]]; then
    zoxide add "$HOME/dev/$selected"   # register so it shows in the sesh/zoxide picker
    sesh connect "$HOME/dev/$selected"
  fi
}

# Use fzf to select and checkout a git branch, sorted by recent activity
gbc() {
  if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "Error: Not in a git repository"
    return 1
  fi
  
  local branch
  branch=$(git for-each-ref --format='%(refname:short) %(committerdate:relative)' --sort=-committerdate refs/heads/ | \
    fzf --height=40% --reverse --prompt="Checkout branch: " | \
    awk '{print $1}')
  
  if [[ -n "$branch" ]]; then
    git checkout "$branch"
  fi
}

# open the current directory in intellij
idea() {
