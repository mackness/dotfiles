# Clear sbt-talon snapshot artifacts from the Coursier cache
clear-talon-snapshots() {
  local cache_dir="$HOME/Library/Caches/Coursier/v1/https/{{ .talonCacheDir }}"
  local dirs=("$cache_dir"/sbt-talon*/*-SNAPSHOT(N/))
  if (( ${#dirs} == 0 )); then
    echo "No sbt-talon snapshot artifacts found."
    return 0
  fi
  echo "Found ${#dirs} snapshot artifact(s):"
  printf '  %s\n' "${dirs[@]}"
  echo ""
  read -q "REPLY?Delete all? [y/N] " && echo && rm -rf "${dirs[@]}" && echo "Deleted." || echo "\nSkipped."
}

# Print the default branch of the current git repo (e.g. main, master)
default-branch() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Not inside a git repository." >&2
    return 1
  fi
  local branch
  # Prefer the remote's HEAD; fall back to local symbolic-ref, then common names
  branch="$(git symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')"
  if [[ -z "$branch" ]]; then
    branch="$(git remote show origin 2>/dev/null | sed -n 's/.*HEAD branch: //p')"
  fi
  if [[ -z "$branch" ]]; then
    for candidate in main master; do
      if git show-ref --verify --quiet "refs/heads/$candidate"; then
        branch="$candidate"
        break
      fi
    done
  fi
  if [[ -z "$branch" ]]; then
    echo "Could not determine default branch." >&2
    return 1
  fi
  echo "$branch"
}

